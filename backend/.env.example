# MongoDB Configuration
MONGO_URI="MONGO_URI"
MONGO_DB="MONGO_DB_NAME"

# JWT Secrets (Generate secure random values for production)
JWT_ACCESS_SECRET="your_secure_access_secret_key_here_change_this"
JWT_REFRESH_SECRET="your_secure_refresh_secret_key_here_change_this"
JWT_ALGORITHM="HS256"

# JWT Cookie Settings
JWT_COOKIE_SECURE="true"
JWT_COOKIE_SAMESITE="Lax"

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES="15"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# Frontend Origins (CORS)
FRONTEND_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080"
